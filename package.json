{
    "name": "DATA_GATEWAY",
    "version": "1.0.0",
    "description": "Internal data query service",
    "main": "app.js",
    "scripts": {
        "dev": "npm run build && node --env-file=.env dist/app.js",
        "build": "eslint src && npx tsc && cp -r src/errors dist && cp src/services/GeoLite2-City.mmdb dist/services/",
        "pre:image": "npm run build && cp package-dist.json dist/package.json && cp .dockerignore dist",
        "zip": "npm run build && cp package*.json dist && cp .env dist",
        "start": "node --env-file=.env app.js"
    },
    "keywords": [
        "data",
        "internal",
        "expressjs"
    ],
    "author": "Animotion Robotics",
    "license": "ISC",
    "dependencies": {
        "@aws-sdk/client-comprehend": "^3.1045.0",
        "@aws-sdk/client-rekognition": "^3.1036.0",
        "@aws-sdk/client-s3": "^3.1033.0",
        "@aws-sdk/client-translate": "^3.1045.0",
        "@aws-sdk/s3-presigned-post": "^3.1045.0",
        "@aws-sdk/s3-request-presigner": "^3.1033.0",
        "axios": "^1.7.7",
        "bcrypt": "^6.0.0",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "maxmind": "^5.0.6",
        "multer": "^2.1.1",
        "pg": "^8.16.3",
        "rate-limiter-flexible": "^7.2.0",
        "redis": "^4.6.12",
        "resend": "^6.10.0",
        "uuid": "^13.0.0",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^2.1.0",
        "@types/node": "^24.3.1",
        "@types/pg": "^8.20.0",
        "@types/ws": "^8.18.1",
        "eslint": "^10.4.1",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.60.1"
    }
}
