### Basic (required)
NODE_ENV=dev
SERVICE_NAME=DATA_GATEWAY
HTTP_PORT=8080

### CORS (comma-separated origins; empty allows none in config — dev uses credentials rule in server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

### IP whitelist (enforced when NODE_ENV is not dev)
IP_WHITELIST=127.0.0.1,10.0.0.1

### JWT public key (choose ONE)
# 1) Fetch public key from auth service
AUTH_HOST=127.0.0.1
AUTH_PORT=7000
# 2) Or load keypair from local directory
KEYPAIR_PATH=./.keys

### Redis (required for cache / messenger / msglist / stream modules)
REDIS_HOSTS=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_USE_CLUSTER=false
REDIS_USE_TLS=false

### Redis Stream consumer (comma-separated stream keys; empty skips consumer loops)
# Example: consume LLM chat stream (retry/:dlq groups are created automatically when missing)
REDIS_STREAMS_LISTEN=llm:chat:REQUEST
REDIS_STREAM_READ_COUNT=10

### Redis Pub/Sub (comma-separated channel names; must match handlers in handlers/messenger)
CHANNEL_LIST=subscribe,unsubscribe,interinstancemessage

### Redis List / msglist (comma-separated list keys; empty skips BLPOP listener)
# Example: LLM chat success queue (service:task:STATUS)
MSG_LIST_LISTEN=llm:chat:SUCCESS

### PostgreSQL (optional; required when init_postgres_modules runs)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USERNAME=postgres
PG_PASSWORD=postgres
PG_DATABASE=postgres
PG_MAX_CONNECTIONS=10
PG_USE_TLS=false

### Platform (comma-separated platform ids)
PLATFORM_LIST=0,1,2,3

### Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

### S3 / media (optional; used by media upload and presigned URLs)
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=
MEDIA_BASE_URL=

### AWS (optional; content safety / region helpers)
AWS_REGION=
AWS_REGION_MAP={}
TEXT_SAFETY_TOXICITY_THRESHOLD=0.5
IMAGE_SAFETY_CONFIDENCE_THRESHOLD=60
