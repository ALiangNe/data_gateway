### Basic (required)
SERVICE_NAME=data_gateway
NODE_ENV=dev
HTTP_PORT=8002

### CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

### IP whitelist (enforced when NODE_ENV is not dev)
IP_WHITELIST=127.0.0.1,10.0.0.1

### JWT public key (fetch from auth service)
AUTH_HOST=127.0.0.1
AUTH_PORT=7000

### OTA service
OTA_HOST_USW1=127.0.0.1
OTA_PORT_USW1=6880
OTA_HOST_EUC1=127.0.0.1
OTA_PORT_EUC1=6880

### Redis
REDIS_HOSTS=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_USE_CLUSTER=false
REDIS_USE_TLS=false
REDIS_STREAM_READ_COUNT=10
REDIS_STREAMS_LISTEN=llm:chat:SUCCESS

### PostgreSQL
PG_HOST_USW1=127.0.0.1
PG_PORT_USW1=5432
PG_USERNAME_USW1=postgres
PG_PASSWORD_USW1=postgres
PG_DATABASE_USW1=postgres
PG_MAX_CONNECTIONS_USW1=10
PG_USE_TLS_USW1=false

PG_HOST_EUC1=127.0.0.1
PG_PORT_EUC1=5432
PG_USERNAME_EUC1=postgres
PG_PASSWORD_EUC1=postgres
PG_DATABASE_EUC1=postgres
PG_MAX_CONNECTIONS_EUC1=10
PG_USE_TLS_EUC1=false

### Platform (comma-separated platform ids)
PLATFORM_LIST=web,slack,robot
