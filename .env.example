### Basic (required)
SERVICE_NAME=data_gateway
NODE_ENV=dev
HTTP_PORT=8002

### CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

### IP whitelist (enforced when NODE_ENV is not dev)
IP_WHITELIST=127.0.0.1,10.0.0.1

### JWT public key (fetch from auth service)
AUTH_HOST=127.0.0.1
AUTH_PORT=7000

### OTA service
OTA_USW1_HOST=127.0.0.1
OTA_USW1_PORT=6880
OTA_EUC1_HOST=127.0.0.1
OTA_EUC1_PORT=6880

### Redis
REDIS_HOSTS=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_USE_CLUSTER=false
REDIS_USE_TLS=false
REDIS_STREAM_READ_COUNT=10
REDIS_STREAMS_LISTEN=llm:chat:SUCCESS

### PostgreSQL
PG_USW1_HOST=127.0.0.1
PG_USW1_PORT=5432
PG_USW1_USERNAME=postgres
PG_USW1_PASSWORD=postgres
PG_USW1_DATABASE=postgres
PG_USW1_MAX_CONNECTIONS=10
PG_USW1_USE_TLS=false

PG_EUC1_HOST=127.0.0.1
PG_EUC1_PORT=5432
PG_EUC1_USERNAME=postgres
PG_EUC1_PASSWORD=postgres
PG_EUC1_DATABASE=postgres
PG_EUC1_MAX_CONNECTIONS=10
PG_EUC1_USE_TLS=false

### Platform (comma-separated platform ids)
PLATFORM_LIST=web,slack,robot
